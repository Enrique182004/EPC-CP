PORT=5001
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PATH=./data/epc.db

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=EPC Credentialing <your-email@gmail.com>

# Google Calendar API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/oauth/callback

# Frontend URL (for CORS and redirect links in emails)
CLIENT_URL=http://localhost:5173
